table Movimentações
	lineageTag: 88a341c6-a6c1-4ce5-9bee-25714bbdb786

	measure Recebimentos =
			CALCULATE(
			    SUM('Movimentações'[Valor da Movimentação]),
			    'Movimentações'[Tipo]="Recebimento"
			)
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 707f8812-847e-4343-ac20-83f4c827805b

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure Pagamentos =
			-CALCULATE(
			    SUM('Movimentações'[Valor da Movimentação]),
			    'Movimentações'[Tipo]="Pagamento"
			)
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 5a02d05b-ea4c-4859-bb47-fc8eea377a74

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure Impostos = [Recebimentos]*0.15
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: f041a464-3dbf-44e0-81d2-ec77c83cf901

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure Lucro = [Recebimentos]-[Pagamentos]-[Impostos]
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: e9c00420-6711-4b4f-ac13-a8a1627fcd08

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure Margem = [Lucro]/[Recebimentos]
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 2d4adb4d-a9e6-42d4-a54c-e72f533785a9

	measure Complemento = 1-[Margem]
		formatString: 0
		lineageTag: 12304900-6550-4010-9934-0deb026578a2

	measure 'Qtd Movimentações' = COUNTROWS('Movimentações')
		formatString: 0
		lineageTag: a0827be7-b5dd-4cd9-966e-959de952f4c1

	measure 'Movimentações PIX' =
			CALCULATE(
			    COUNTROWS('Movimentações'),
			    'Movimentações'[Forma Pagamento]="Pix"
			)
		formatString: 0
		lineageTag: d40426e6-a237-4199-82cf-92c4a16cbb60

	measure '% PIX' = 'Movimentações'[Movimentações PIX]/[Qtd Movimentações]
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e6e74009-becc-4822-baf6-5f4c7f65938d

	measure 'Desvio Meta' = [Margem]-0.3
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 5aa534cb-3a16-41f4-9d51-0d7f099aa05f

